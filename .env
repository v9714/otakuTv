# OtakuTv Frontend Environment Variables Example
# Copy this file to .env and update the values for production

# VITE_AUTH_API_URL=http://localhost:8000
# VITE_CONTENT_API_URL=http://localhost:8001
# VITE_USER_API_URL=http://localhost:8002
# VITE_INTERACTION_API_URL=http://localhost:8003
# VITE_COMMENTS_API_URL=http://localhost:8004
# VITE_MANGA_API_URL=http://localhost:8005

VITE_AUTH_API_URL=https://otakutv.in/api/auth
VITE_CONTENT_API_URL=https://otakutv.in/api/content
VITE_USER_API_URL=https://otakutv.in/api/user
VITE_INTERACTION_API_URL=https://otakutv.in/api/interaction
VITE_COMMENTS_API_URL=https://otakutv.in/api/comments
VITE_MANGA_API_URL=https://otakutv.in/api/manga

# Site Configuration
VITE_SITE_NAME=OtakuTv
VITE_SITE_DESCRIPTION=Your Ultimate Anime Streaming Platform

# Feature Flags
# Set to "true" to enable anime section (routes + navbar links)
# Set to "false" to hide all anime features (manga-only mode)
VITE_ANIME_ENABLED=false
